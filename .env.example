# ─────────────────────────────────────────────────────────────────────────────
# kaiban-distributed-examples — environment template
# Copy to `.env` and fill in the keys for the example(s) you want to run.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM provider (choose ONE) ────────────────────────────────────────────────
# Standard OpenAI:
OPENAI_API_KEY=
# …or any OpenAI-compatible endpoint (Ollama/vLLM/LM Studio):
# OPENAI_BASE_URL=http://localhost:11434/v1
# …or OpenRouter (takes priority over OPENAI_API_KEY when set):
# OPENROUTER_API_KEY=
# Model id (default gpt-4o-mini; for OpenRouter use e.g. openai/gpt-4o-mini):
LLM_MODEL=gpt-4o-mini

# ── Agent tools (@kaibanjs/tools) — only needed by the examples that use them ─
# Trip Planning / Company Research (web search). Set the one matching your tool:
TAVILY_API_KEY=
SERPER_API_KEY=
# RAG Knowledge Base needs an OpenAI key specifically for embeddings,
# even if your chat LLM is OpenRouter/local. It reuses OPENAI_API_KEY above,
# or set a dedicated embeddings key here:
# RAG_OPENAI_API_KEY=

# ── Messaging / infrastructure ───────────────────────────────────────────────
MESSAGING_DRIVER=bullmq          # bullmq (Redis, default) | kafka
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092     # only for MESSAGING_DRIVER=kafka

# ── Gateway (board + A2A + health) ───────────────────────────────────────────
GATEWAY_URL=http://localhost:3000
VALID_HITL_DECISIONS=PUBLISH,REVISE,REJECT

# ── Workflow spend guard (0 = unlimited) ─────────────────────────────────────
MAX_WORKFLOW_COST_USD=0.50
MAX_WORKFLOW_TOKENS=0
